{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./out",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNEXT"] // ← NO "dom" here — only for extension code
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "out",
    "dist",
    ".vscode",
    "extension-original.ts",
    "src/webview-ui", // ← most important line
    "src/webview-ui/**", // sometimes needed for deeper safety
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
