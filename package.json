{
  "name": "test-ext",
  "displayName": "test-ext",
  "description": "schema to crud app",
  "version": "0.0.1",
  "type": "module",
  "extensionKind": [
    "workspace"
  ],
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:test-ext.crudTest"
  ],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbanem/test-ext.git"
  },
  "license": "MIT",
  "publisher": "mbanem",
  "contributes": {
    "commands": [
      {
        "command": "test-ext.crudTest",
        "title": "CRUD TEST-EXT"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run buildx",
    "buildx": "esbuild ./src/extension.ts --bundle --outfile=out/main.mjs --external:vscode --format=esm --platform=node --target=node18",
    "buildx:webview": "vite build --config src/webview-ui/vite.config.ts",
    "installx": "clear; pnpm buildx:webview && vsce package --no-dependencies && VERSION=$(jq -r '.version' package.json) && code --install-extension test-ext-${VERSION}.vsix",
    "all": "pnpm buildx && vsce package --no-dependencies && VERSION=$(jq -r '.version' package.json) && code --install-extension test-ext-${VERSION}.vsix",
    "compile": "tsc -p .",
    "check": "eslint .",
    "dev": "clear; vite dev",
    "build:webview": "cd src/webview-ui && pnpm run build",
    "last two": "are all you need",
    "build": "pnpm compile && pnpm build:webview",
    "install": "pnpm build; vsce package --no-dependencies && VERSION=$(jq -r '.version' package.json) && code --install-extension test-ext-${VERSION}.vsix"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/config": "^7.8.0",
    "@prisma/internals": "^7.8.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bcrypt": "latest",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "pg": "^8.21.0",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.2",
    "prisma": "^7.8.0",
    "sass": "^1.100.0",
    "sass-embedded": "^1.100.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vite-plugin-sass-dts": "^1.3.37"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
