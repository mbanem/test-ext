{
  "name": "test-ext",
  "displayName": "test-ext",
  "description": "test multi page",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbanem/test-ext.git"
  },
  "license": "MIT",
  "publisher": "mbanem",
  "contributes": {
    "commands": [
      {
        "command": "test-ext.crudTest",
        "title": "CRUD TEST-EXT"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "check": "eslint .",
    "dev": "clear; vite dev",
    "build:webview": "vite build --config src/webview-ui/vite.config.ts",
    "build": "pnpm compile && pnpm build:webview",
    "install": "pnpm build && vsce package --no-dependencies && VERSION=$(jq -r '.version' package.json) && code --install-extension test-ext-${VERSION}.vsix"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bcrypt": "latest",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "postcss": "^8.5.6",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "sass": "^1.97.3",
    "svelte": "^5.50.0",
    "svelte-check": "^4.3.6",
    "svelte-preprocess": "^6.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-sass-dts": "^1.3.35"
  },
  "dependencies": {
    "@types/vscode": "^1.109.0",
    "dotenv": "^17.3.1",
    "tslib": "^2.8.1"
  }
}
