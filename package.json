{
  "name": "test-ext",
  "displayName": "test-ext",
  "description": "test multi page",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/mbanem/test-ext.git"
  },
  "license": "MIT",
  "publisher": "mbanem",
  "contributes": {
    "commands": [
      {
        "command": "test-ext.crudTest",
        "title": "CRUD TEST-EXT"
      },
      {
        "command": "test-ext.generateEventHandlers",
        "title": "TEST-EXT: Generate Event Handlers Registry"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "check": "eslint .",
    "vite:dev": "clear; vite dev",
    "buildx:webview": "vite build --config src/webview-ui/vite.config.ts",
    "build:webview": "cd src/webview-ui && pnpm run build",
    "watch:ext": "tsc -watch -p .",
    "dev:webview": "pnpm --filter webview-ui dev",
    "dev": "concurrently \"pnpm watch:ext\" \"pnpm dev:webview\"",
    "build": "clear; pnpm compile && pnpm build:webview",
    "package": "vsce package --no-dependencies",
    "install:vsix": "VERSION=$(jq -r '.version' package.json) && code --install-extension test-ext-${VERSION}.vsix",
    "release": "pnpm build && pnpm package && pnpm install:vsix",
    "install": "vsce package --no-dependencies && VERSION=$(jq -r '.version' package.json); code --install-extension test-ext-${VERSION}.vsix"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/bcrypt": "latest",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "config,": "link:@eslint/compat,@eslint/js,@prisma/config,",
    "eslint": "link:@types/pg,@types/eslint",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "node,typescript,typescript-eslint,vite,vite-plugin-sass-dts": "link:@types/pg,@types/eslint@sveltejs/vite-plugin-svelte,@tsconfig/svelte,tslib,@types/bcrypt,@types/node,@typescript-eslint/eslint-plugin,@typescript-eslint/parser,eslint,eslint-config-prettier,eslint-plugin-svelte,globals,postcss,postcss-load-config,prettier,prettier-plugin-svelte,prisma,sass,sass-embedded,svelte,svelte-check,svelte-preprocess,ts-node,@types/node,typescript,typescript-eslint,vite,vite-plugin-sass-dts",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "prisma": "^7.8.0",
    "sass": "^1.100.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "svelte-preprocess": "^6.0.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^7.3.3",
    "vite-plugin-sass-dts": "^1.3.37"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@types/vscode": "^1.120.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "internals,bcrypt,dotenv,pg,tslib": "link:@prisma/adapter-pg,@prisma/client,@prisma/internals,bcrypt,dotenv,pg,tslib",
    "pg": "^8.21.0",
    "tslib": "^2.8.1"
  }
}
