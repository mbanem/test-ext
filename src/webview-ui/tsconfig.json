{
  "extends": "./tsconfig.base.json", // ← relative, no package resolution issues
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "baseUrl": ".",
    "paths": {
      "$lib/*": ["src/lib/*"]
    },
    "types": ["vite/client", "svelte"] // ← fixes import.meta.hot
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "vite-env.d.ts"],
  "references": [{ "path": "./tsconfig.node.json" }],
  "exclude": ["node_modules", "dist"]
}
